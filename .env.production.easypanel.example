NODE_ENV=production
PORT=3333
HOST=0.0.0.0

APP_URL=https://api.r2rmarketingdigital.com.br
PUBLIC_URL=https://api.r2rmarketingdigital.com.br
FRONTEND_URL=https://crm.r2rmarketingdigital.com.br
CORS_ORIGIN=https://crm.r2rmarketingdigital.com.br,https://api.r2rmarketingdigital.com.br
PUBLIC_DIR=/app/frontend-public_html

RATE_LIMIT_MAX=240
RATE_LIMIT_WINDOW_MS=60000
JSON_BODY_LIMIT_BYTES=2000000
INTEGRATION_TIMEOUT_MS=20000
ALLOW_DEMO_AUTH=false
ALLOW_EMAIL_PROFILE_LINK=false
AUTO_LINK_AUTH_PROFILE=true
ALLOW_GLOBAL_INTEGRATION_FALLBACK=false

SUPABASE_URL=COLE_AQUI_A_URL_DO_SUPABASE
SUPABASE_PUBLISHABLE_KEY=COLE_AQUI_A_CHAVE_PUBLICA_OU_ANON
SUPABASE_ANON_KEY=COLE_AQUI_A_CHAVE_PUBLICA_OU_ANON
SUPABASE_SERVICE_ROLE_KEY=COLE_AQUI_A_SERVICE_ROLE_KEY
SUPABASE_SECRET_KEY=

DATA_DIR=.data
UPLOAD_DIR=.data/uploads
UPLOAD_MAX_BYTES=10000000
UPLOAD_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,application/pdf,text/plain,text/csv

EVOLUTION_API_URL=https://COLE_AQUI_DOMINIO_VALIDO_DA_EVOLUTION
EVOLUTION_API_URL_FALLBACK=
EVOLUTION_API_KEY=COLE_AQUI_A_API_KEY_GLOBAL_DA_EVOLUTION
EVOLUTION_INSTANCE_API_KEY=COLE_AQUI_A_API_KEY_DA_INSTANCIA_SE_EXISTIR
EVOLUTION_FORCE_ENV_CREDENTIALS=true
EVOLUTION_INSTANCE_NAME=Ruan
EVOLUTION_INSTANCE=Ruan
EVOLUTION_WEBHOOK_SECRET=COLE_AQUI_UM_SEGREDO_LONGO
EVOLUTION_WEBHOOK_EMPRESA_ID=COLE_AQUI_UUID_DA_EMPRESA_SE_NECESSARIO

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.6

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://api.r2rmarketingdigital.com.br/api/meta/oauth/callback
META_GRAPH_VERSION=v20.0
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.r2rmarketingdigital.com.br/api/google/oauth/callback
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_CUSTOMER_ID=
N8N_WEBHOOK_URL=

PAYMENT_PROVIDER=checkout_link
BILLING_WEBHOOK_SECRET=COLE_AQUI_UM_SEGREDO_DO_PROVEDOR_DE_PAGAMENTO
CHECKOUT_STARTER_URL=
CHECKOUT_BUSINESS_URL=
CHECKOUT_PREMIUM_URL=
PAYMENT_WHATSAPP=
PAYMENT_ALLOW_WHATSAPP_FALLBACK=true
BILLING_LOG_DIR=.data
