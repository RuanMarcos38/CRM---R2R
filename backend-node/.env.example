# R2R CRM SaaS - variaveis de ambiente
# Copie para .env e preencha. Nunca versionar o .env real.

# Servidor
NODE_ENV=production
PORT=3000
APP_URL=https://api.seudominio.com.br
FRONTEND_URL=https://crm.seudominio.com.br
PUBLIC_DIR=
PUBLIC_URL=https://api.seudominio.com.br
CORS_ORIGIN=https://crm.seudominio.com.br,http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_MAX=240
RATE_LIMIT_WINDOW_MS=60000
JSON_BODY_LIMIT_BYTES=2000000

# Supabase publico - estes valores podem ser enviados ao navegador
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Compatibilidade com projetos antigos:
SUPABASE_ANON_KEY=

# Supabase secreto - somente backend
SUPABASE_SERVICE_ROLE_KEY=
# Nova nomenclatura de chaves secretas, se estiver usando:
SUPABASE_SECRET_KEY=

# Token interno opcional, se voce adicionar JWT proprio no futuro.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Desenvolvimento local sem Supabase configurado
# Em producao, mantenha false.
ALLOW_DEMO_AUTH=false
DEMO_USER_EMAIL=admin@demo.local
DATA_DIR=.data

# OpenAI / IA comercial
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.6
AI_SYSTEM_PROMPT=Voce e um agente comercial consultivo do CRM. Responda em portugues do Brasil com clareza, contexto de funil e foco em proxima acao.

# Evolution API / WhatsApp - nunca colocar no frontend
EVOLUTION_API_URL=
# Alias legado aceito pelo backend:
EVOLUTION_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=r2r-crm

# Meta Ads / Meta Lead Ads - nunca colocar no frontend
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_000000000000000

# N8N / automacoes
N8N_WEBHOOK_URL=

# Checkout / assinaturas
PAYMENT_PROVIDER=checkout_link
CHECKOUT_STARTER_URL=
CHECKOUT_BUSINESS_URL=
CHECKOUT_PREMIUM_URL=
PAYMENT_WHATSAPP=
PAYMENT_ALLOW_WHATSAPP_FALLBACK=true
BILLING_LOG_DIR=.data
