# R2R CRM SaaS — Backend Enterprise
NODE_ENV=production
PORT=3000

# URLs públicas
FRONTEND_URL=https://crm.r2rmarketingdigital.com.br
API_URL=https://api.r2rmarketingdigital.com.br
PUBLIC_API_BASE=https://api.r2rmarketingdigital.com.br
CORS_ORIGIN=https://crm.r2rmarketingdigital.com.br,https://r2rmarketingdigital.com.br
PUBLIC_DIR=public

# Supabase — service role fica APENAS no backend
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=cole_a_anon_key
SUPABASE_SERVICE_ROLE_KEY=cole_a_service_role_key_somente_no_backend

# Segurança
WEBHOOK_SECRET=gere_um_token_forte_para_webhooks
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
MAX_BODY_BYTES=5000000

# Admin inicial — criar usuário no Supabase Auth e vincular no SQL de seed
ADMIN_EMAIL=admin@r2rmarketingdigital.com.br

# OpenAI / IA
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.4
AI_SYSTEM_PROMPT=Você é o agente comercial profissional do CRM R2R.

# Evolution API / WhatsApp
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=r2r-crm
EVOLUTION_WEBHOOK_TOKEN=

# n8n
N8N_WEBHOOK_URL=
N8N_WEBHOOK_TOKEN=

# Meta / Google — configurar no backend, nunca no frontend
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
